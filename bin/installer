#!/bin/sh

BIN_DIR="$(dirname "$(realpath "$0")")"
ROOT_DIR="$(realpath "${BIN_DIR}/..")"
readonly BIN_DIR
readonly ROOT_DIR

main() {
  # Make install directory
  _data_dir="${XDG_DATA_DIR:-"${HOME}/.local/share"}"
  _install_root="${_data_dir}/kwin/scripts"
  unset _data_dir

  mkdir -p "${_install_root}" || return 1

  # Move built files over
  cp -r "${ROOT_DIR}/dist/"* "${_install_root}" || return 1

  unset _install_root

  return 0
}

main "$@" || exit 1
exit 0
